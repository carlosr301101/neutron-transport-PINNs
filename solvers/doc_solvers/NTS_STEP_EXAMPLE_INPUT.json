  "program_overview": {
    "name": "NTS_STEP.c",
    "purpose": "Solves 2D neutron transport equation using characteristic STEP method with directional sweeps",
    "method_description": "Performs directional sweeps (SW→NE, NW→SE, etc.) using characteristic stepping along angular rays",
    "advantages": "Fast convergence (15-30 iter), physically intuitive, excellent with beam-like sources",
    "computational_cost": "Similar to LD (20-30 iterations typical)",
    "input_parameters": "11 parameters identical to DD/LD/RM methods",
    "output_format": "JSON with STATUS, ITER, CPU, MFLUX, MFLOW, XFLOW, YFLOW"
  },

  "method_explanation": {
    "name": "STEP Method",
    "full_name": "Short Characteristics STEP (Sweep Through Each Point)",
    "principle": "Follows neutron rays along characteristic directions with stepping",
    "sweep_pattern": "4 directional sweeps per iteration:",
    "sweeps": [
      "SW → NE (Southwest to Northeast) - directions m < M/4",
      "NW → SE (Northwest to Southeast) - directions M/4 ≤ m < M/2",
      "NE → SW (Northeast to Southwest) - directions M/2 ≤ m < 3M/4",
      "SE → NW (Southeast to Northwest) - directions 3M/4 ≤ m < M"
    ],
    "stepping": "Along each ray, advance by step size h in characteristic direction",
    "advantages_of_sweeps": "Natural flow of information, no matrix inversions, physically intuitive",
    "comparison_to_dd": "STEP more physically motivated, DD more mathematical"
  },

