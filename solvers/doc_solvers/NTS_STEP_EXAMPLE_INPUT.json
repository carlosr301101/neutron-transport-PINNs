  "parameter_definitions": {
    "note": "Input parameters identical to all previous methods (11 parameters)",
    "N": {
      "name": "Quadrature Order",
      "valid_values": [2, 4, 6, 8, 10, 12, 14, 16, 18],
      "formula": "M = N*(N+2)/2",
      "recommendation": "4-6 for STEP (4 typical)",
      "note": "More directions = more sweeps per iteration"
    },
    "NZ": {
      "name": "Number of Material Zones",
      "constraint": "≥ 1",
      "recommendation": "STEP handles multiple zones efficiently"
    },
    "ZONES": {
      "name": "Zone Properties",
      "format": "sigma_t sigma_s [cm^-1]",
      "constraint": "sigma_s < sigma_t (critical)"
    },
    "NR_X, XDOM": {
      "name": "X Domain Discretization",
      "recommendation": "5-7 nodes per region typical"
    },
    "NR_Y, YDOM": {
      "name": "Y Domain Discretization",
      "recommendation": "5-7 nodes per region typical"
    },
    "ZMAP": {
      "name": "Zone Map",
      "format": "NR_Y × NR_X matrix with 1-based indices"
    },
    "QMAP": {
      "name": "Source Map",
      "format": "NR_Y × NR_X matrix",
      "note": "STEP handles localized/beam sources very well"
    },
    "BC": {
      "name": "Boundary Conditions",
      "format": "BOTTOM TOP LEFT RIGHT",
      "valid": [-1.0 (symmetry), 0.0 (vacuum), >0 (specified)]
    },
    "TOL": {
      "name": "Convergence Tolerance",
      "range": "0 < tol < 1",
      "recommended": "1e-5 standard",
      "note": "STEP converges quickly, 1e-5 achievable in 20-30 iter"
    }
  },

  "sweep_algorithm_details": {
    "iteration_structure": "For each iteration k:",
    "steps": [
      "Loop over all M directions",
      "For each direction m, determine sweep quadrant:",
      "  - SW→NE: Start at (0,0), proceed right then up",
      "  - NW→SE: Start at (0,max_y), proceed right then down",
      "  - NE→SW: Start at (max_x,max_y), proceed left then down",
      "  - SE→NW: Start at (max_x,0), proceed left then up",
      "For each cell in sweep order:",
      "  - Get incoming fluxes from upstream neighbors",
      "  - Step along characteristic using balance equation",
      "  - Update outgoing flux to downstream neighbors",
      "Check convergence: if ERR < tol, STOP"
    ],
    "balance_equation": "miu*dPhi/dx + theta*dPhi/dy + sigma_t*Phi = sigma_s*Phi_avg + Q",
    "discretization": "Diamond difference scheme for spatial derivatives"
  },

