# ============================================================
# NTS Automation - Archivos Generados (No necesarios en repo)
# ============================================================

# Outputs generados por el sistema
outputs/inputs/*.txt
outputs/results/*.txt
outputs/results/*.json
outputs/logs/*.log

# Mantener estructura de directorios
!outputs/inputs/.gitkeep
!outputs/results/.gitkeep
!outputs/logs/.gitkeep

